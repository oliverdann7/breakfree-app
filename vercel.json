{
  "buildCommand": "npm install --no-audit --no-fund --prefer-offline && npx expo export --platform web --output-dir dist && mv dist/index.html dist/app.html && cp breakfree-landing-web.html dist/index.html",
  "outputDirectory": "dist",
  "installCommand": "echo 'install runs inside buildCommand'",
  "framework": null,
  "cleanUrls": true,
  "rewrites": [
    { "source": "/app", "destination": "/app.html" },
    { "source": "/app/(.*)", "destination": "/app.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    }
  ]
}
