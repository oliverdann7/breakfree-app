{
  "name": "breakfree-app",
  "version": "1.0.0",
  "description": "BreakFree Türkiye - Premium wellness community app",
  "main": "index.js",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "eject": "expo eject",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "prepare": "husky install",
    "eas:build:preview": "eas build --platform all --profile preview",
    "eas:build:production": "eas build --platform all",
    "eas:submit": "eas submit --platform all"
  },
  "dependencies": {
    "expo": "^51.0.0",
    "expo-constants": "^16.0.0",
    "expo-linking": "^6.0.0",
    "expo-notifications": "^0.28.0",
    "expo-splash-screen": "^0.27.0",
    "expo-status-bar": "^1.12.0",
    "react": "^18.3.0",
    "react-native": "^0.74.0",
    "react-native-gesture-handler": "^2.16.0",
    "react-native-reanimated": "^3.13.0",
    "react-native-safe-area-context": "^4.10.0",
    "react-native-screens": "^3.32.0",
    "@react-navigation/bottom-tabs": "^6.6.1",
    "@react-navigation/native": "^6.1.18",
    "@react-navigation/stack": "^6.4.1",
    "@reduxjs/toolkit": "^1.9.7",
    "react-redux": "^8.1.3",
    "redux-persist": "^6.0.0",
    "axios": "^1.6.8",
    "firebase": "^10.7.0",
    "react-hook-form": "^7.50.0",
    "yup": "^1.3.3",
    "react-i18next": "^14.0.0",
    "i18next": "^23.7.6",
    "react-native-chart-kit": "^6.12.0",
    "victory-native": "^37.0.1",
    "react-native-svg": "^14.1.0",
    "react-native-paper": "^5.11.0",
    "lodash": "^4.17.21",
    "moment": "^2.29.4"
  },
  "devDependencies": {
    "@babel/core": "^7.23.6",
    "@babel/preset-env": "^7.23.6",
    "@babel/preset-react": "^7.23.3",
    "@babel/preset-typescript": "^7.23.3",
    "@testing-library/react": "^14.1.2",
    "@testing-library/react-native": "^12.4.1",
    "babel-jest": "^29.7.0",
    "eslint": "^8.55.0",
    "eslint-config-react-app": "^7.0.1",
    "eslint-plugin-react": "^7.33.2",
    "eslint-plugin-react-native": "^5.0.0",
    "jest": "^29.7.0",
    "jest-mock-axios": "^4.6.1",
    "prettier": "^3.1.1",
    "husky": "^8.0.3",
    "lint-staged": "^15.2.2",
    "typescript": "^5.3.3",
    "@types/react": "^18.2.42",
    "@types/react-native": "^0.73.0"
  },
  "jest": {
    "preset": "react-native",
    "testEnvironment": "node",
    "setupFilesAfterEnv": ["<rootDir>/jest.setup.js"],
    "transformIgnorePatterns": [
      "node_modules/(?!(react-native|@react-navigation|@react-native-community|react-native-screens|react-native-gesture-handler|react-native-reanimated)/)"
    ],
    "collectCoverageFrom": [
      "app/**/*.{js,jsx}",
      "!app/**/*.test.js",
      "!app/**/index.js",
      "!app/App.js"
    ]
  },
  "prettier": {
    "semi": true,
    "trailingComma": "es5",
    "singleQuote": true,
    "printWidth": 100,
    "tabWidth": 2
  },
  "lint-staged": {
    "*.{js,jsx}": ["eslint --fix", "prettier --write"],
    "*.json": ["prettier --write"]
  }
}
