# Copy this file to .env.local and fill in your Firebase credentials.
# Get these values from https://console.firebase.google.com → Project settings → Your apps.
# NEVER commit .env.local to version control.

EXPO_PUBLIC_FIREBASE_API_KEY=your-api-key-here
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
EXPO_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=000000000000
EXPO_PUBLIC_FIREBASE_APP_ID=1:000000000000:web:xxxxxxxxxxxxxxxx

# Optional — defaults to https://api.breakfree.app/v1
# EXPO_PUBLIC_API_URL=http://localhost:3001/v1
